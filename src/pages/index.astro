---
import { Image, getImage } from "astro:assets";
import BaseLayout from "@/components/BaseLayout.astro";
import BrandMark from "@/components/BrandMark.astro";
import QuoteForm from "@/components/QuoteForm.astro";
import { createFormToken, getFormTokenSecret } from "@/lib/quote";
import heroVault from "@/assets/images/hero-vault.webp";
import protocolDetail from "@/assets/images/protocol-detail.webp";
import collectionTypes from "@/assets/images/collection-types.webp";

export const prerender = false;

const title = "Move Collections | Transporte concierge de cartas e colecionáveis em São Paulo";
const description = "Coleta dedicada, acondicionamento e entrega acompanhada para cartas TCG e colecionáveis em São Paulo capital e arredores.";
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const formToken = createFormToken(getFormTokenSecret(), Date.now() - 2_000);
const ogImageResult = await getImage({ src: heroVault, width: 1200, height: 630, fit: "cover", format: "webp", quality: 82 });
const ogImage = new URL(ogImageResult.src, Astro.url);

const faqItems = [
  {
    question: "Quais itens vocês transportam?",
    answer: "Cards avulsos, decks, slabs, produtos selados, miniaturas, figuras e outros colecionáveis de pequeno ou médio porte. Antes de confirmar, avaliamos dimensões, fragilidade, condição e rota.",
  },
  {
    question: "A Move Collections oferece seguro?",
    answer: "Ainda não. O valor declarado ajuda a entender o cuidado e a rota necessários, mas não cria seguro ou cobertura financeira. Essa limitação é confirmada antes do agendamento.",
  },
  {
    question: "Onde o serviço está disponível?",
    answer: "Atendemos São Paulo capital e arredores com equipe própria. A disponibilidade depende da origem, destino, janela de atendimento e características do item.",
  },
  {
    question: "Como o item é acondicionado?",
    answer: "Definimos o acondicionamento após a avaliação. Sleeves, cases, separadores, proteção contra movimento e embalagem externa são escolhidos conforme formato, condição e sensibilidade do colecionável.",
  },
  {
    question: "Vocês transportam cartas Pokémon e Magic: The Gathering?",
    answer: "Sim, podemos avaliar cartas e produtos desses e de outros TCGs. A Move Collections é um serviço independente e não possui afiliação com Pokémon, Nintendo, Wizards of the Coast ou Magic: The Gathering.",
  },
  {
    question: "Como acompanho o transporte?",
    answer: "A equipe mantém contato direto desde a confirmação da coleta até a entrega. O formato das atualizações é combinado no agendamento para que você saiba quem está com o item e qual é a próxima etapa.",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: "Move Collections",
    url: canonical.toString(),
    description,
    areaServed: [
      { "@type": "City", name: "São Paulo" },
      { "@type": "AdministrativeArea", name: "Região Metropolitana de São Paulo" },
    ],
    serviceType: "Transporte concierge de cartas TCG e colecionáveis",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer },
    })),
  },
];

const protocolSteps = [
  ["Avaliação", "Entendemos o item, a condição, as dimensões e a rota."],
  ["Agendamento", "Definimos janela, responsáveis e pontos de contato."],
  ["Registro", "Documentamos a condição e o acondicionamento acordado."],
  ["Acondicionamento", "Escolhemos proteção compatível com cada peça."],
  ["Transporte", "A equipe própria conduz o item na rota confirmada."],
  ["Entrega", "Conferimos o recebimento e encerramos o acompanhamento."],
];
---

<BaseLayout {title} {description} {canonical} {ogImage} {jsonLd}>
  <header class="site-header">
    <div class="container site-header__inner">
      <BrandMark />
      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Abrir menu" data-nav-toggle>
        <span></span><span></span>
      </button>
      <nav id="site-nav" class="site-nav" aria-label="Navegação principal" data-site-nav data-open="false">
        <a href="#protocolo">Protocolo</a>
        <a href="#para-quem">Para quem</a>
        <a href="#itens">Itens</a>
        <a href="#perguntas">Perguntas</a>
        <a class="button button--outline site-nav__cta" href="#avaliacao">Solicitar avaliação</a>
      </nav>
    </div>
  </header>

  <main id="conteudo">
    <section id="top" class="hero" aria-labelledby="hero-title">
      <div class="hero__media" data-tilt>
        <Image
          src={heroVault}
          alt="Mãos com luvas posicionam cuidadosamente um card genérico encapsulado em uma bandeja de conservação."
          widths={[640, 960, 1280, 1920]}
          sizes="(min-width: 960px) 60vw, 100vw"
          layout="full-width"
          format="avif"
          quality={84}
          fetchpriority="high"
        />
        <div class="hero__media-shade"></div>
      </div>
      <div class="container hero__inner">
        <div class="hero__copy">
          <p class="kicker">Transporte concierge para colecionáveis</p>
          <h1 id="hero-title">Sua coleção não é carga comum.</h1>
          <p class="hero__lead">
            Coleta dedicada, registro de condição, acondicionamento e entrega acompanhada por uma equipe própria que entende o que está em suas mãos.
          </p>
          <div class="hero__actions">
            <a class="button button--primary" href="#avaliacao">Solicitar avaliação</a>
            <a class="text-link" href="#protocolo">
              Conhecer o protocolo
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13m-5-5 5 5-5 5" /></svg>
            </a>
          </div>
          <p class="hero__region"><span></span> São Paulo capital e arredores · rotas sob avaliação</p>
        </div>
      </div>
      <div class="hero__assurances" aria-label="Diferenciais do serviço">
        <div class="container hero__assurances-inner">
          <p><strong>Equipe própria</strong><span>Contato direto do início à entrega</span></p>
          <p><strong>Condição registrada</strong><span>O cuidado começa antes da coleta</span></p>
          <p><strong>Atendimento individual</strong><span>Cada item e rota são avaliados</span></p>
        </div>
      </div>
    </section>

    <section class="section manifesto" aria-labelledby="manifesto-title">
      <div class="container manifesto__grid">
        <div class="manifesto__statement">
          <p class="section-note">O que muda quando o item importa</p>
          <h2 id="manifesto-title" class="section-title">Valor cultural não cabe na etiqueta do frete.</h2>
        </div>
        <div class="manifesto__body">
          <p class="section-intro">
            No transporte comum, a peça vira volume. Na Move, ela começa como uma história: edição, estado, fragilidade, destino e motivo da entrega.
          </p>
          <p>
            É dessa leitura que nasce o protocolo. Não prometemos eliminar todo risco — mostramos como cada decisão de cuidado é tomada e quem responde pela próxima etapa.
          </p>
        </div>
      </div>
    </section>

    <section id="protocolo" class="section protocol" aria-labelledby="protocol-title">
      <div class="container protocol__intro">
        <div>
          <p class="section-note">Uma cadeia de cuidado visível</p>
          <h2 id="protocol-title" class="section-title">Do primeiro contato à conferência final.</h2>
        </div>
        <p class="section-intro">Você sabe o que acontece, por que acontece e quem está conduzindo cada etapa.</p>
      </div>
      <div class="container protocol__track-wrap">
        <ol class="protocol__track" data-protocol-track data-active="false">
          {protocolSteps.map(([title, text], index) => (
            <li style={`--step: ${index}`}>
              <span class="protocol__number">{String(index + 1).padStart(2, "0")}</span>
              <h3>{title}</h3>
              <p>{text}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="care-detail" aria-labelledby="care-title">
      <div class="care-detail__media">
        <Image
          src={protocolDetail}
          alt="Detalhe de materiais protetores e ferramentas de conferência sobre uma superfície teal escura."
          widths={[640, 960, 1400]}
          sizes="(min-width: 900px) 55vw, 100vw"
          layout="full-width"
          format="avif"
          quality={82}
          loading="lazy"
        />
      </div>
      <div class="care-detail__content">
        <p class="section-note">Cuidado que pode ser explicado</p>
        <h2 id="care-title" class="section-title">Precisão sem ritual vazio.</h2>
        <p>Materiais, separação, estabilidade e embalagem externa são definidos conforme o item — nunca por um pacote genérico.</p>
        <ul class="care-detail__list">
          <li><span class="care-detail__dot" aria-hidden="true"></span> Conferência antes do deslocamento</li>
          <li><span class="care-detail__dot" aria-hidden="true"></span> Proteção contra atrito e movimento</li>
          <li><span class="care-detail__dot" aria-hidden="true"></span> Contato direto durante o atendimento</li>
        </ul>
      </div>
    </section>

    <section id="para-quem" class="section audiences" aria-labelledby="audiences-title">
      <div class="container">
        <div class="audiences__heading">
          <h2 id="audiences-title" class="section-title">Para quem coleciona. Para quem faz a cultura circular.</h2>
        </div>
        <div class="audiences__split">
          <article>
            <span class="audiences__index">A</span>
            <h3>Colecionadores</h3>
            <p>Compras, trocas, mudanças de acervo e entregas especiais tratadas com atenção proporcional à história do item.</p>
            <a class="text-link" href="#avaliacao">Avaliar meu envio <span aria-hidden="true">→</span></a>
          </article>
          <article>
            <span class="audiences__index">B</span>
            <h3>Lojas e vendedores</h3>
            <p>Transferências e pedidos especiais conduzidos com comunicação clara para preservar a confiança construída com o cliente.</p>
            <a class="text-link" href="#avaliacao">Avaliar uma entrega <span aria-hidden="true">→</span></a>
          </article>
        </div>
      </div>
    </section>

    <section id="itens" class="section items" aria-labelledby="items-title">
      <div class="container items__grid">
        <div class="items__content">
          <h2 id="items-title" class="section-title">Pequenos no tamanho. Grandes no significado.</h2>
          <p class="section-intro">A aceitação depende de condição, dimensões, fragilidade e rota. Estes são os formatos mais comuns.</p>
          <ul class="items__list">
            <li><strong>Cards e decks</strong><span>Avulsos, em sleeves, binders compactos ou deck boxes.</span></li>
            <li><strong>Slabs e cases</strong><span>Peças encapsuladas, graded ou em cases rígidos.</span></li>
            <li><strong>Produtos selados</strong><span>Boxes, kits e itens lacrados de pequeno porte.</span></li>
            <li><strong>Miniaturas e figuras</strong><span>Itens frágeis avaliados individualmente.</span></li>
          </ul>
        </div>
        <div class="items__media">
          <Image
            src={collectionTypes}
            alt="Cards genéricos, slab, caixa selada e miniatura apresentados como peças de acervo."
            widths={[640, 960, 1400]}
            sizes="(min-width: 900px) 48vw, 100vw"
            layout="constrained"
            format="avif"
            quality={82}
            loading="lazy"
          />
          <p>Outros colecionáveis de pequeno e médio porte podem ser avaliados.</p>
        </div>
      </div>
    </section>

    <section class="section region" aria-labelledby="region-title">
      <div class="container region__grid">
        <div class="region__map" aria-hidden="true">
          <svg viewBox="0 0 520 380">
            <path class="region__contour" d="M64 244c30-88 95-139 184-161 82-20 151 7 198 72 31 43 24 92-20 131-53 47-133 63-217 52-82-10-169-29-145-94Z" />
            <path class="region__route" d="M107 273c56-22 75-86 136-95 47-7 58 44 112 35 29-5 46-31 67-49" />
            <circle cx="243" cy="178" r="7" />
            <circle cx="355" cy="213" r="5" />
          </svg>
          <span>SP</span>
        </div>
        <div class="region__content">
          <h2 id="region-title" class="section-title">São Paulo capital e arredores.</h2>
          <p class="section-intro">A operação regional permite que a equipe própria mantenha o contato e o cuidado de ponta a ponta.</p>
          <p>Consulte sua origem e destino. A confirmação considera distância, janela, acesso e características do item.</p>
          <a class="text-link" href="#avaliacao">Consultar minha rota <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <section id="avaliacao" class="section quote" aria-labelledby="quote-title">
      <div class="container quote__grid">
        <div class="quote__intro">
          <p class="section-note">Comece pela avaliação</p>
          <h2 id="quote-title" class="section-title">Conte o que precisa se mover.</h2>
          <p class="section-intro">A equipe avalia o item, a rota e o acondicionamento antes de confirmar disponibilidade e valor.</p>
          <div class="quote__note">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 4 6v5c0 5 3.4 8.4 8 10 4.6-1.6 8-5 8-10V6l-8-3Z" /><path d="M12 8v5m0 3h.01" /></svg>
            <p><strong>Transparência primeiro.</strong> O serviço ainda não inclui seguro. O valor declarado é apenas informativo e ajuda na avaliação operacional.</p>
          </div>
        </div>
        <div class="quote-shell">
          <QuoteForm {formToken} />
        </div>
      </div>
    </section>

    <section id="perguntas" class="section faq" aria-labelledby="faq-title">
      <div class="container faq__grid">
        <div class="faq__intro">
          <h2 id="faq-title" class="section-title">Perguntas importantes, respostas diretas.</h2>
        </div>
        <div class="faq__list">
          {faqItems.map((item, index) => (
            <details open={index === 0}>
              <summary>
                <span>{item.question}</span>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m7 9 5 5 5-5" /></svg>
              </summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container site-footer__top">
      <div>
        <BrandMark />
        <p>Transporte concierge para cartas TCG e colecionáveis em São Paulo capital e arredores.</p>
      </div>
      <a class="button button--outline site-footer__cta" href="#avaliacao">Solicitar avaliação</a>
    </div>
    <div class="container site-footer__bottom">
      <p>© {new Date().getFullYear()} Move Collections.</p>
      <p>Serviço independente, sem afiliação com Pokémon, Nintendo, Wizards of the Coast ou Magic: The Gathering.</p>
    </div>
  </footer>

  <script>
    import "@/scripts/site";
  </script>
</BaseLayout>

<style>
  .site-header {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    z-index: var(--z-header);
    border-bottom: 1px solid oklch(0.31 0.022 180 / 0.52);
    background: oklch(0.095 0 0 / 0.82);
    backdrop-filter: blur(12px);
  }

  .site-header__inner {
    display: flex;
    min-height: 5rem;
    align-items: center;
    justify-content: space-between;
  }

  .nav-toggle {
    position: relative;
    z-index: calc(var(--z-nav) + 1);
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-content: center;
    gap: 0.4rem;
    border: 0;
    background: transparent;
    color: var(--color-ink);
  }

  .nav-toggle span {
    width: 1.35rem;
    height: 1px;
    background: currentColor;
    transition: transform 180ms var(--ease-out);
  }

  .nav-toggle[aria-expanded="true"] span:first-child { transform: translateY(0.2rem) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:last-child { transform: translateY(-0.2rem) rotate(-45deg); }

  .site-nav {
    position: fixed;
    inset: 0;
    z-index: var(--z-nav);
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    gap: 0.35rem;
    padding: 7.5rem var(--gutter) 3rem;
    background: var(--color-bg);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-1rem);
    transition: opacity 220ms var(--ease-out), transform 220ms var(--ease-out);
  }

  .site-nav[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .site-nav > a:not(.button) {
    display: flex;
    width: 100%;
    min-height: 3.5rem;
    align-items: center;
    border-bottom: 1px solid var(--color-line);
    font-size: 1.15rem;
    text-decoration: none;
  }

  .site-nav__cta { margin-top: 1.5rem; }

  .hero {
    position: relative;
    display: grid;
    min-height: 100svh;
    padding-top: 5rem;
    isolation: isolate;
  }

  .hero__media {
    --tilt-x: 0deg;
    --tilt-y: 0deg;
    --shift-x: 0px;
    --shift-y: 0px;
    position: relative;
    z-index: -2;
    min-height: 45vh;
    order: 2;
    overflow: hidden;
    perspective: 1200px;
  }

  .hero__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 62% center;
    transform: translate3d(var(--shift-x), var(--shift-y), 0) rotateX(var(--tilt-x)) rotateY(var(--tilt-y)) scale(1.025);
    transition: transform 260ms var(--ease-out);
  }

  .hero__media-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, var(--color-bg));
  }

  .hero__inner {
    display: flex;
    align-items: center;
    order: 1;
    min-height: 34rem;
    padding-block: 8rem var(--space-lg);
  }

  .hero__copy {
    max-width: 49rem;
    animation: hero-copy 760ms var(--ease-expo) both;
  }

  .hero h1 {
    max-width: 10.5ch;
    margin: var(--space-sm) 0 var(--space-md);
    font-size: var(--text-display);
    font-weight: 340;
    letter-spacing: -0.035em;
    line-height: 0.98;
  }

  .hero__lead {
    max-width: 43rem;
    margin: 0;
    color: oklch(0.82 0.016 180);
    font-size: var(--text-lead);
    line-height: 1.58;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-md);
    margin-top: var(--space-lg);
  }

  .hero__region {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin: var(--space-lg) 0 0;
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .hero__region span {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--color-primary-strong);
    box-shadow: 0 0 0 0.25rem oklch(0.58 0.105 180 / 0.14);
  }

  .hero__assurances {
    align-self: end;
    order: 3;
    border-block: 1px solid var(--color-line);
    background: oklch(0.105 0.004 180 / 0.94);
  }

  .hero__assurances-inner {
    display: grid;
  }

  .hero__assurances p {
    display: grid;
    gap: 0.15rem;
    margin: 0;
    padding: 1.15rem 0;
    border-bottom: 1px solid var(--color-line);
  }

  .hero__assurances p:last-child { border-bottom: 0; }
  .hero__assurances strong { font-size: var(--text-sm); font-weight: 600; }
  .hero__assurances span { color: var(--color-muted); font-size: var(--text-xs); }

  .manifesto {
    background: var(--color-ink);
    color: var(--color-bg);
  }

  .manifesto .section-note { color: oklch(0.43 0.08 180); }
  .manifesto__grid { display: grid; gap: var(--space-xl); }
  .manifesto__statement { display: grid; gap: var(--space-lg); }
  .manifesto .section-title { max-width: 14ch; }
  .manifesto__body { display: grid; align-content: end; gap: var(--space-md); }
  .manifesto__body .section-intro { color: oklch(0.29 0.018 180); }
  .manifesto__body > p:last-child { max-width: 58ch; margin: 0; color: oklch(0.42 0.016 180); }

  .protocol { overflow: hidden; }
  .protocol::after {
    position: absolute;
    right: -9rem;
    bottom: -12rem;
    width: 32rem;
    height: 32rem;
    border: 1px solid var(--color-line);
    border-radius: 50%;
    box-shadow: 0 0 0 5rem oklch(0.58 0.105 180 / 0.035), 0 0 0 10rem oklch(0.58 0.105 180 / 0.025);
    content: "";
  }

  .protocol__intro { position: relative; z-index: 1; display: grid; gap: var(--space-lg); }
  .protocol__intro > div { display: grid; gap: var(--space-lg); }
  .protocol__track-wrap { position: relative; z-index: 1; overflow-x: auto; padding-top: var(--space-2xl); scrollbar-width: thin; }
  .protocol__track {
    display: grid;
    min-width: 74rem;
    margin: 0;
    padding: 0 0 var(--space-lg);
    grid-template-columns: repeat(6, 1fr);
    list-style: none;
  }

  .protocol__track li {
    position: relative;
    min-height: 14rem;
    padding: var(--space-lg) var(--space-md) 0 0;
    border-top: 1px solid var(--color-line);
    opacity: 0.45;
    transform: translateX(-0.75rem);
    transition: opacity 420ms var(--ease-out), transform 420ms var(--ease-out), border-color 420ms var(--ease-out);
    transition-delay: calc(var(--step) * 70ms);
  }

  .protocol__track li::before {
    position: absolute;
    top: -0.3rem;
    left: 0;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--color-bg);
    border: 1px solid var(--color-metal);
    content: "";
  }

  .protocol__track[data-active="true"] li { opacity: 1; transform: translateX(0); border-color: var(--color-primary); }
  .protocol__number { color: var(--color-metal); font-size: var(--text-xs); font-variant-numeric: tabular-nums; letter-spacing: 0.1em; }
  .protocol__track h3 { margin: 2.5rem 0 var(--space-2xs); font-size: clamp(1rem, 0.95rem + 0.25vw, 1.16rem); font-weight: 600; }
  .protocol__track p { max-width: 15rem; margin: 0; color: var(--color-muted); font-size: var(--text-sm); line-height: 1.55; }

  .care-detail { display: grid; background: var(--color-surface); }
  .care-detail__media { min-height: 28rem; overflow: hidden; }
  .care-detail__media :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .care-detail__content { display: grid; align-content: center; gap: var(--space-md); padding: var(--space-2xl) var(--gutter); }
